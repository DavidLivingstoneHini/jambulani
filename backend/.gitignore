# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb
.Python
*.egg-info/
dist/
build/
wheels/

# ── Virtual environments ──────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment / secrets ─────────────────────────────────────────
# .env is NEVER committed — it contains real credentials
.env

# ── Django ────────────────────────────────────────────────────────
staticfiles/
media/
db.sqlite3
*.log

# ── uv ────────────────────────────────────────────────────────────
# uv.lock SHOULD be committed in a real project for reproducibility.
# It is excluded here only because it requires network access to generate
# with valid hashes — run `uv lock` after cloning to create it.
uv.lock

# ── IDE ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.project
.pydevproject

# ── OS ────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini
