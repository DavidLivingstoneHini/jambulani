# Copy this file to .env before running locally:
#   cp .env.example .env
#
# Django
# Generate a real one for production:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev-only-insecure-key-replace-before-deploying-to-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL
# These must match what's in docker-compose.db.yml exactly
POSTGRES_DB=jambulani_db
POSTGRES_USER=jambulani_user
POSTGRES_PASSWORD=jambulani_pass_2024
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Frontend origin (CORS)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000