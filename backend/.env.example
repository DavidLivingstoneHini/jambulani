# Copy this file to .env before running:
#   cp .env.example .env
#
# No edits needed — all defaults work out of the box with Docker.

# Django
SECRET_KEY=dev-only-insecure-key-replace-before-deploying-to-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL
POSTGRES_DB=jambulani_db
POSTGRES_USER=jambulani_user
POSTGRES_PASSWORD=jambulani_pass_2024
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Frontend origin (CORS)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000